generator client {
  provider = "prisma-client"
  output   = "generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model pdf {
  id         String      @id @default(uuid()) @db.Uuid
  file_name  String      @db.VarChar(100)
  created_at DateTime    @default(now())
  user_id    String      @db.Uuid
  file_hash  String      @unique @db.VarChar(100)
  user       user        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pdf_chunks pdf_chunk[]

  // for querying user's pdfs
  @@index([user_id])
}

model pdf_chunk {
  id         String                @id @default(uuid()) @db.Uuid
  pdf_id     String                @db.Uuid
  chunk_text String
  embedding  Unsupported("vector")
  pdf        pdf                   @relation(fields: [pdf_id], references: [id], onDelete: Cascade)

  // used for JOIN query
  @@index([pdf_id])
}

model user {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique @db.VarChar(255)
  password      String         @db.VarChar(70)
  name          String         @default("default_name") @db.VarChar(50)
  created_at    DateTime       @default(now())
  pdfs          pdf[]
  conversations conversation[]
}

model conversation {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  created_at DateTime  @default(now())
  messages   message[]
  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // for conversations query in descending order (latest to oldest)
  @@index([user_id, created_at(sort: Desc)])
}

model message {
  id              String       @id @default(uuid()) @db.Uuid
  conversation_id String       @db.Uuid
  content         String
  role            Role
  created_at      DateTime     @default(now())
  type            MessageType  @default(SUCCESS)
  seq             Int          @default(autoincrement())
  conversation    conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  // for messages query in descending order (latest to oldest)
  @@index([conversation_id, created_at(sort: Desc), seq(sort: Desc)])
}

enum Role {
  USER
  ASSISTANT
}

enum MessageType {
  NO_RESULT
  SUCCESS
}
